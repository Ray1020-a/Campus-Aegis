# ============================================================
# Campus Aegis 校園神盾 — 環境變數範本
# 複製此檔案為 .env 並填入實際數值
# ============================================================

# ------------------------------------------------------------
# VyOS 路由器設定（必填）
# ------------------------------------------------------------
# VyOS 的 HTTPS 位址（需啟用 HTTP API）
VYOS_URL=https://192.168.1.1

# VyOS HTTP API 金鑰（在 VyOS 執行 set service https api keys id <id> key <key> 取得）
VYOS_API_KEY=

# 設為 1 時跳過 TLS 憑證驗證（自簽憑證環境使用，預設 0）
VYOS_INSECURE=0

# ------------------------------------------------------------
# Google Gemini AI 設定（必填）
# ------------------------------------------------------------
# Google AI Studio 取得：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini 模型（預設 gemini-2.0-flash）
GEMINI_MODEL=gemini-2.0-flash

# AI 防禦分析週期（秒，預設 120）
DEFENSE_INTERVAL_SECONDS=120

# ------------------------------------------------------------
# 管理員面板設定（必填）
# ------------------------------------------------------------
# 管理員面板登入密碼（必填）
ADMIN_PASSWORD=

# Session 加密金鑰（建議設為獨立的隨機字串，預設同 ADMIN_PASSWORD）
ADMIN_SESSION_SECRET=

# 管理員面板監聽埠（預設 3000）
ADMIN_PORT=3000

# 管理員面板綁定位址（預設 0.0.0.0，若有 Nginx 反代建議改為 127.0.0.1）
ADMIN_BIND=0.0.0.0

# ------------------------------------------------------------
# NetFlow 收集器設定
# ------------------------------------------------------------
# 啟用 NetFlow 收集器（1=啟用，0=停用，預設 1）
NETFLOW_ENABLED=1

# NetFlow UDP 監聽埠（預設 2055，需與 VyOS sFlow/NetFlow 匯出設定一致）
NETFLOW_PORT=2055

# NetFlow 綁定位址（預設 0.0.0.0）
NETFLOW_BIND=0.0.0.0

# ------------------------------------------------------------
# PCAP 封包捕捉設定（選填，需 root 權限）
# ------------------------------------------------------------
# 啟用 pcap 封包捕捉（1=啟用，0=停用，預設 0）
PCAP_ENABLED=0

# pcap 監聽的網路介面名稱（預設 eth0）
PCAP_INTERFACE=eth0

# ------------------------------------------------------------
# 誘騙服務設定
# ------------------------------------------------------------
# 誘騙服務監聽埠（預設 3099，供 Nginx 導向攻擊者流量）
DECEPTION_PORT=3099

# 誘騙服務綁定位址（預設 127.0.0.1，僅本機，透過 Nginx 對外）
DECEPTION_BIND=127.0.0.1

# 誘騙回應延遲毫秒（預設 0，可設較大值讓攻擊者請求耗時）
DECEPTION_DELAY_MS=0

# ------------------------------------------------------------
# 資料庫設定
# ------------------------------------------------------------
# SQLite 資料庫路徑（相對於專案根目錄或絕對路徑，預設 data/defense.db）
DB_PATH=data/defense.db

# ------------------------------------------------------------
# 日誌設定
# ------------------------------------------------------------
# 日誌等級：error | warn | info | debug（預設 info）
LOG_LEVEL=info
